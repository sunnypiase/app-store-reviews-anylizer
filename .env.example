# Copy this file to .env and adjust values if needed:
#   cp .env.example .env

# How the app connects to Postgres.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
#
# Running the app straight on your machine (no Docker)? Leave this as-is —
# "localhost" is correct.
# Running via `docker compose up`? You don't need to touch this either —
# the app container builds its own connection string from the POSTGRES_*
# values below, using "db" (the Postgres container's name) instead of
# "localhost".
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/reviews

# Postgres credentials. These start the Postgres container itself, and
# also feed into the app's connection string when running via Docker
# (see above). Change them if you want something other than the defaults.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=reviews

# Optional. Powers sentiment classification AND actionable-insight
# generation in GET /api/v1/insights and /api/v1/reports (get one free at
# https://aistudio.google.com/apikey). Leave unset and the app falls back to
# local alternatives — VADER for sentiment, TF-IDF keyword themes for
# actionable insights — less accurate, but no API key or network call
# required. Current model rate limits:
# https://ai.google.dev/gemini-api/docs/rate-limits
GEMINI_API_KEY=
# Model used for sentiment classification.
# GEMINI_MODEL_NAME=gemini-flash-lite-latest
# Model used for actionable-insight generation. Must be a stable model with
# structured-output support (https://ai.google.dev/gemini-api/docs/models).
# GEMINI_INSIGHTS_MODEL_NAME=gemini-3.1-flash-lite
# Per-attempt timeout for the insight-generation request.
# GEMINI_INSIGHTS_REQUEST_TIMEOUT_SECONDS=30
