# Copy this file to .env and adjust values if needed:
#   cp .env.example .env

# How the app connects to Postgres.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
#
# Running the app straight on your machine (no Docker)? Leave this as-is —
# "localhost" is correct.
# Running via `docker compose up`? You don't need to touch this either —
# the app container builds its own connection string from the POSTGRES_*
# values below, using "db" (the Postgres container's name) instead of
# "localhost".
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/reviews

# Postgres credentials. These start the Postgres container itself, and
# also feed into the app's connection string when running via Docker
# (see above). Change them if you want something other than the defaults.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=reviews
